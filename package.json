{
  "name": "dpavo-pizza-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "optimize-images": "node scripts/optimize-images.mjs",
    "remotion:studio": "remotion studio src/remotion/index.ts",
    "remotion:render": "remotion render src/remotion/index.ts DPavoPromo out/dpavo-promo.mp4",
    "record:website": "node scripts/record-website.mjs",
    "test": "playwright test",
    "test:a11y": "playwright test tests/a11y.spec.ts",
    "test:visual": "playwright test tests/visual.spec.ts",
    "test:visual:update": "playwright test tests/visual.spec.ts --update-snapshots",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": ".next/static/chunks/pages/_app*.js",
      "limit": "250 kB",
      "gzip": true
    },
    {
      "path": ".next/static/chunks/main*.js",
      "limit": "100 kB",
      "gzip": true
    }
  ],
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/edge-config": "^1.4.3",
    "@vercel/speed-insights": "^2.0.0",
    "canvas-confetti": "^1.9.4",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "splitting": "^1.1.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@remotion/bundler": "^4.0.448",
    "@remotion/cli": "^4.0.448",
    "@remotion/google-fonts": "^4.0.448",
    "@remotion/player": "^4.0.448",
    "@remotion/renderer": "^4.0.448",
    "@remotion/transitions": "^4.0.448",
    "@size-limit/file": "^12.1.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "playwright": "^1.59.1",
    "remotion": "^4.0.448",
    "size-limit": "^12.1.0",
    "typescript": "^5"
  }
}
